# Copy to .env and fill in your own keys (.env is gitignored — never commit it).

# FPT.AI — Vietnamese Text-to-Speech (spoken replies)
FPT_API_KEY=your_fpt_api_key_here

# Groq — LLM for the agent + cheap geocode model
GROQ_API_KEY=your_groq_llm_key_here
GROQ_MODEL=openai/gpt-oss-120b
GROQ_GEOCODE_MODEL=llama-3.1-8b-instant

# Groq — Whisper Speech-to-Text (use a SEPARATE key so STT has its own quota)
GROQ_WHISPER_KEY=your_groq_whisper_key_here
GROQ_WHISPER_MODEL=whisper-large-v3-turbo

# Optional: real web-search grounding for geocoding (else Groq + Nominatim)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# MongoDB — local default works with: mongod --dbpath ./mongo-data
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=voicego
DEMO_PASSENGER_ID=demo-passenger-visual
